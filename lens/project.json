{
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "name": "msw-lens",
  "projectType": "library",
  "sourceRoot": "lens/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build",
        "cwd": "lens"
      },
      "outputs": ["{workspaceRoot}/lens/dist"]
    }
  }
}
