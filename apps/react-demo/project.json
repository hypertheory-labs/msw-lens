{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "react-demo",
  "projectType": "application",
  "sourceRoot": "apps/react-demo/src",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite",
        "cwd": "apps/react-demo"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build",
        "cwd": "apps/react-demo"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite preview",
        "cwd": "apps/react-demo"
      }
    }
  }
}
